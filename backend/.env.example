# ──────────────────────────────────────────────────────────────────────────────
# F1 Navigator Backend — Environment Variables
# Copy this file to .env and fill in your actual values
# ──────────────────────────────────────────────────────────────────────────────

# ─ Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string (hosted on Railway, Render, Supabase, etc.)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/f1_navigator

# ─ OpenAI API ─────────────────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxx

# ─ Pinecone Vector Database ───────────────────────────────────────────────────
# Get from: https://www.pinecone.io/
PINECONE_INDEX_NAME=edtech
PINECONE_HOST=https://edtech-xxxx.svc.aped-4627-b74a.pinecone.io
PINECONE_NAMESPACE=

# ─ Email Notifications (Gmail) ────────────────────────────────────────────────
# Generate app password: https://myaccount.google.com/apppasswords
# (Enable 2FA in Google Account first)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=noreply@f1navigator.com

# ─ Frontend URL (for CORS) ────────────────────────────────────────────────────
# Local: http://localhost:3000
# Production: https://your-vercel-domain.vercel.app
FRONTEND_URL=http://localhost:3000

# ─ Optional Settings ──────────────────────────────────────────────────────────
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBED_MODEL=text-embedding-3-large
TOP_K_SEMANTIC=30
TOP_N_TO_LLM=7
SEMANTIC_WEIGHT=0.6
